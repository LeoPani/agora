DATABASE_URL=postgres://agora:agora_dev@localhost:5433/agora?sslmode=disable
API_ADDR=:8081
LOG_LEVEL=info
LOG_FORMAT=json
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=10
DB_CONN_MAX_LIFETIME=30m
API_READ_TIMEOUT=15s
API_WRITE_TIMEOUT=120s

# ── LLMs ────────────────────────────────────────────────────────────────────
GROQ_API_KEY=
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
BRAVE_API_KEY=

# Roteamento padrão (groq | gemini | anthropic | ollama)
LLM_PROVIDER_DEFAULT=groq
LLM_MODEL_DEFAULT=llama-3.3-70b-versatile
LLM_MODEL_HEAVY=gemini-2.0-flash

# Ollama local (opcional — custo zero)
OLLAMA_HOST=http://localhost:11434

# Observabilidade
ENABLE_LLM_LOGGING=true
LLM_LOG_PATH=./logs/llm_calls.jsonl

# Kill switch diário em USD (mata chamadas se superar)
LLM_COST_LIMIT_DAILY_USD=5.00
